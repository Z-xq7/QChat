#apply_sure_wid #sure_btn[state='normal']  {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(240,240,240, 200),  /* 淡色 */
               stop:1 rgba(220,220,230, 200)); /* 淡色 */
    color: #2cb46e;
    font-size: 16px; /* 设置字体大小 */
    font-family: "Microsoft YaHei"; /* 设置字体 */
    border-radius: 8px; /* 设置圆角 */
}

#apply_sure_wid #sure_btn[state='hover'] {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(210,210,210, 200),  /* 淡色 */
               stop:1 rgba(190,190,210, 200)); /* 淡色 */
    color: #2cb46e;
    font-size: 16px; /* 设置字体大小 */
    font-family: "Microsoft YaHei"; /* 设置字体 */
    border-radius: 8px; /* 设置圆角 */
}

#apply_sure_wid #sure_btn[state='press'] {
