/* 登录相关对话框 */
QDialog#LoginDialog,RegisterDialog,ResetDialog{
    background-color:transparent; /* 设置为透明背景 */
    border-radius: 10px; /* 添加圆角 */
}

QLineEdit {
    border: none;
    background-color: rgba(240,240,240, 180);
    border-radius: 6px;
    /*padding: 3px;*/
}

#pass_visible[state='unvisible']{
   border-image: url(:/images/unvisible_black.png);
}

#pass_visible[state='unvisible_hover']{
   border-image: url(:/images/unvisible_blue.png);
}

#pass_visible[state='visible']{
   border-image: url(:/images/visible_black.png);
}

#pass_visible[state='visible_hover']{
   border-image: url(:/images/visible_blue.png);
}

#confirm_visible[state='unvisible']{
   border-image: url(:/images/unvisible_black.png);
}

#confirm_visible[state='unvisible_hover']{
   border-image: url(:/images/unvisible_blue.png);
}

#confirm_visible[state='visible']{
   border-image: url(:/images/visible_black.png);
}

#confirm_visible[state='visible_hover']{
   border-image: url(:/images/visible_blue.png);
}

#forget_label[state='normal'],#forget_label[state='selected']{
    color: white; /* 白色文字 */
}

#forget_label[state='hover'],#forget_label[state='selected_hover']{
    color: rgb(173, 216, 230); /* 浅蓝色 */
}

/* 主界面样式 */
#side_bar{
   background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
               stop:0 rgba(220,255,255, 220),  /* 浅蓝色 */
               stop:0.5 rgba(235,248,255, 220), /* 中等浅蓝 */
               stop:1 rgba(255,235,255, 220)); /* 浅粉色 */
   border-top-left-radius: 0px;
   border-bottom-left-radius: 0px;
}

#add_btn[state='normal']{
    border-image: url(:/images/add_friend_normal.png);
}
#add_btn[state='hover']{
    border-image: url(:/images/add_friend_hover.png);
}
#add_btn[state='press']{
    border-image: url(:/images/add_friend.png);
}

#search_wid{
   background-color: rgba(232,255,255, 180); /* 浅蓝透明 */
}

#chat_user_wid{
    background-color: rgba(232,255,255, 180); /* 浅蓝透明 */
}

#chat_user_list {
    background-color: rgba(232,255,255, 180); /* 浅蓝透明 */
    border: none;
    border-radius: 8px;
}
#chat_user_list::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(200,238,238, 220),  /* 淡蓝 */
               stop:1 rgba(173,216,230, 220)); /* 浅蓝 */
    border: 1px solid rgba(173,216,230, 150);
    border-radius: 6px;
    outline: none;
}
#chat_user_list::item:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(200,240,250, 200),  /* 淡蓝 */
               stop:1 rgba(180,220,240, 200)); /* 浅蓝 */
    border-radius: 6px;
    outline: none;
}
#chat_user_list::focus {
    border: 1px solid rgba(135,206,235, 150); /* 天蓝色边框 */
    outline: none;
}

/* 聊天用户列表项 */
#user_chat_lb{
    color: rgb(100,100,100); /* 深灰色 */
    font-size: 12px;
    font-family: "Microsoft YaHei";
}

#user_name_lb{
    color: rgb(50,50,50); /* 深灰色 */
    font-size: 14px;
    font-weight: normal;
    font-family: "Microsoft YaHei";
}

#time_wid #time_lb{
   color: rgb(120,120,120); /* 中等灰色 */
   font-size: 12px;
   font-family: "Microsoft YaHei";
}

/* 滚动条样式 */
QScrollBar:vertical {
    background: transparent; /* 将轨道背景设置为透明 */
    width: 8px; /* 滚动条宽度，根据需要调整 */
    margin: 0px; /* 移除滚动条与滑块之间的间距 */
}

QScrollBar::handle:vertical {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(176,224,230, 200),  /* 浅蓝色 */
               stop:1 rgba(255,228,225, 200)); /* 浅粉色 */
    min-height: 10px; /* 滑块最小高度，根据需要调整 */
    border-radius: 4px; /* 滑块边缘圆角，调整以形成椭圆形状 */
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px; /* 移除上下按钮 */
    border: none; /* 移除边框 */
    background: transparent; /* 背景透明 */
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none; /* 页面滚动部分背景透明 */
}

LoadingDialog{
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
               stop:0 rgba(176,224,230, 150),  /* 浅蓝色 */
               stop:1 rgba(255,228,225, 150)); /* 浅粉色 */
}

/* 聊天界面标题栏 */
#title_wid{
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(240,255,255, 200),  /* 浅蓝 */
               stop:1 rgba(255,245,255, 200)); /* 浅粉 */
}

#title_lb{
    background: transparent;
    color: rgb(50,50,50); /* 深灰色文字 */
    font-family: "Microsoft YaHei";
    font-size: 18px;
    font-weight: normal;
}

/* 聊天输入框 */
#chatEdit{
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
               stop:0 rgba(245,255,255, 180),  /* 浅蓝 */
               stop:1 rgba(250,255,250, 180)); /* 更浅的蓝 */
    border: 1px solid rgba(176,224,230, 150); /* 浅蓝色边框 */
    font-family: "Microsoft YaHei"; /* 设置字体 */
    font-size: 18px; /* 设置字体大小 */
    padding: 8px; /* 设置内边距 */
    border-radius: 10px; /* 圆角边框 */
}

#chatEdit:focus{
    border: 2px solid rgba(135,206,235, 200); /* 天蓝色边框 */
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
               stop:0 rgba(250,255,255, 200),  /* 浅蓝 */
               stop:1 rgba(255,250,255, 200)); /* 浅粉 */
}

/* 发送区域 */
#send_wid{
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(245,255,255, 180),  /* 浅蓝 */
               stop:1 rgba(255,245,255, 180)); /* 浅粉 */
    border-top: 1px solid rgba(176,224,230, 100); /* 浅蓝色边框 */
}

/* 按钮样式 */
#receive_btn[state='normal']{
   background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(255,210,230, 200),  /* 浅粉 */
               stop:1 rgba(255,180,210, 200)); /* 深一点的粉 */
   color: #000000;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 8px; /* 设置圆角 */
   border: 1px solid rgba(255,180,210, 100); /* 添加边框 */
   min-height: 27px;
}

#receive_btn[state='hover']{
   background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(255,190,210, 220),  /* 浅粉 */
               stop:1 rgba(255,160,190, 220)); /* 深一点的粉 */
   color: #000000;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 8px; /* 设置圆角 */
   border: 1px solid rgba(255,160,190, 150); /* 添加边框 */
   min-height: 27px;
}

#receive_btn[state='press']{
   background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(255,160,170, 220),  /* 深粉 */
               stop:1 rgba(255,140,160, 220)); /* 更深的粉 */
   color: #000000;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 8px; /* 设置圆角 */
   border: 1px solid rgba(255,140,160, 150); /* 添加边框 */
   min-height: 27px;
}

#send_btn[state='normal']{
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(255,210,230, 200),  /* 浅粉 */
               stop:1 rgba(255,180,210, 200)); /* 深一点的粉 */
    color: #000000;
    font-size: 14px; /* 设置字体大小 */
    font-family: "Microsoft YaHei"; /* 设置字体 */
    border-radius: 8px; /* 设置圆角 */
    border: 1px solid rgba(255,180,210, 100); /* 添加边框 */
    min-height: 27px;
}

#send_btn[state='hover']{
   background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(255,190,210, 220),  /* 浅粉 */
               stop:1 rgba(255,160,190, 220)); /* 深一点的粉 */
   color: #000000;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 8px; /* 设置圆角 */
   border: 1px solid rgba(255,160,190, 150); /* 添加边框 */
   min-height: 27px;
}

#send_btn[state='press']{
   background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
               stop:0 rgba(255,160,170, 220),  /* 深粉 */
               stop:1 rgba(255,140,160, 220)); /* 更深的粉 */
   color: #000000;
   font-size: 14px; /* 设置字体大小 */
   font-family: "Microsoft YaHei"; /* 设置字体 */
   border-radius: 8px; /* 设置圆角 */
   border: 1px solid rgba(255,140,160, 150); /* 添加边框 */
   min-height: 27px;
}

