/* 搜索框 */
#search_edit {
    border: 1px solid rgba(176,224,230, 150); /* 浅蓝色边框 */
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
               stop:0 rgba(240,255,255, 180),  /* 浅蓝 */
               stop:1 rgba(245,250,255, 180)); /* 浅蓝粉 */
    border-radius: 6px;
    padding: 5px;
}

#search_edit:focus {
    border: 1px solid rgba(135,206,235, 200); /* 天蓝色边框 */
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
               stop:0 rgba(245,255,255, 200),  /* 浅蓝 */
               stop:1 rgba(250,250,255, 200)); /* 浅蓝粉 */
}

/* 搜索框列表*/
#search_list {
    background-color: rgba(232,255,255, 180); /* 浅蓝透明 */
    border: 1px solid rgba(176,224,230, 100); /* 浅蓝色边框 */
}
#search_list::item:selected {
    background-color: rgba(200,238,238, 200); /* 淡蓝 */
    border: none;
    outline: none;
}
#search_list::item:hover {
    background-color: rgba(173,216,230, 180); /* 浅蓝 */
    border: none;
    outline: none;
}
#search_list::focus {
    border: none;
    outline: none;
}

